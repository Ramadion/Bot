{
  "name": "bot-whatsapp-negocio",
  "version": "1.0.0",
  "description": "Asistente de WhatsApp con IA, turnos y pedidos personalizados",
  "main": "main.js",
  "scripts": {
    "start": "node index.js",
    "electron": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.botwhatsapp.negocio",
    "productName": "Bot WhatsApp Negocio",
    "files": [
      "index.js",
      "main.js",
      "config.js",
      "config.json",
      "public/**/*",
      "horarios.json",
      "turnos.json",
      "trabajos.json"
    ],
    "win": {
      "target": "nsis",
      "icon": null
    },
    "linux": {
      "target": "AppImage",
      "icon": null,
      "executableArgs": ["--no-sandbox", "--use-gl=swiftshader"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "keywords": ["whatsapp", "bot", "turnos", "negocio", "ia"],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@google/generative-ai": "^0.24.1",
    "express": "^5.2.1",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.34.7"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2"
  }
}
